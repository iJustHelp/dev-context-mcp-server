          },
          "totalCalls": {
            "type": "integer",
            "format": "int64"
          },
          "statusCounts": {
            "$ref": "#/components/schemas/StatusBreakdown"
          },
          "latencyMs": {
            "$ref": "#/components/schemas/LatencySummary"
          }
        }
      },
      "AnalyticsTimeSeries": {
        "required": [
          "bucket",
          "tool",
